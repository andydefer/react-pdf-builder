{
    "name": "@andy-defer/react-pdf-builder",
    "version": "1.1.2",
    "description": "Build PDF documents with React and Tailwind CSS",
    "license": "MIT",
    "type": "module",
    "main": "dist/index.umd.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.umd.js",
            "default": "./dist/index.umd.js"
        },
        "./styles": {
            "import": "./dist/styles.css",
            "default": "./dist/styles.css"
        },
        "./styles.css": {
            "import": "./dist/styles.css",
            "default": "./dist/styles.css"
        },
        "./fonts/*": {
            "import": "./dist/fonts/*"
        }
    },
    "files": [
        "dist",
        "dist/fonts",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "type-check": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "react": "^18.2.0 || ^19.0.0",
        "react-dom": "^18.2.0 || ^19.0.0"
    },
    "dependencies": {
        "class-variance-authority": "^0.7.0",
        "html2canvas": "^1.4.1",
        "jsbarcode": "^3.12.3",
        "jspdf": "^2.5.1",
        "pdf-lib": "^1.17.1",
        "qrcode.react": "^4.2.0"
    },
    "devDependencies": {
        "@types/jsbarcode": "^3.11.4",
        "@types/node": "^22.13.5",
        "@types/qrcode.react": "^1.0.5",
        "@types/react": "^18.2.0 || ^19.0.0",
        "@types/react-dom": "^18.2.0 || ^19.0.0",
        "autoprefixer": "^10.4.20",
        "postcss": "^8.4.49",
        "react": "^18.2.0 || ^19.0.0",
        "react-dom": "^18.2.0 || ^19.0.0",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.3.0",
        "vite": "^5.0.0",
        "vite-plugin-dts": "^3.6.0"
    },
    "keywords": [
        "pdf",
        "react",
        "tailwind",
        "invoice",
        "generator",
        "html2canvas",
        "jspdf"
    ],
    "author": {
        "name": "Andy Defer",
        "email": "andy@defer.dev",
        "url": "https://github.com/andy-defer"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/andy-defer/react-pdf-builder.git"
    },
    "bugs": {
        "url": "https://github.com/andy-defer/react-pdf-builder/issues"
    },
    "homepage": "https://github.com/andy-defer/react-pdf-builder#readme"
}